---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Réalisations — Marwan Bridi">
  <section class="section">
    <h2>Réalisations</h2>
    <p class="muted" style="margin-bottom: 2rem;">Projets personnels et explorations techniques.</p>
  </section>

  <div class="card reveal">
    <h3>RAG Contractuel</h3>
    <p class="desc">Recherche sémantique sur les documents contractuels en construction. Extraction automatique des clauses, prix unitaires, conditions.</p>
    <span class="badge">IA + Construction</span>
  </div>

  <div class="card reveal">
    <h3>Knowledge Graph Pipeline</h3>
    <p class="desc">Pipeline d'extraction d'entités depuis un vault Obsidian vers Neo4j. Détection de relations, résolution d'alias, couches de sécurité.</p>
    <span class="badge">NLP + Graph</span>
  </div>

  <div class="card reveal">
    <h3>Personal-OS</h3>
    <p class="desc">Système de knowledge management — Obsidian + Claude Code + n8n + Neo4j. Skills markdown, daily loops automatisées, veille IA structurée.</p>
    <span class="badge">Productivité + IA</span>
  </div>

  <div class="card reveal">
    <h3>Base de prix unitaires</h3>
    <p class="desc">Extraction et structuration automatique de prix unitaires depuis les soumissions CFC. 8'356 positions, 68 CFC, 9 projets.</p>
    <span class="badge">Data + Construction</span>
  </div>
</BaseLayout>
