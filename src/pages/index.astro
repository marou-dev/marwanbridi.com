---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <!-- Intro — serif, light weight, one statement -->
  <section class="mb-20 md:mb-24">
    <p class="text-xl md:text-2xl leading-relaxed" style="font-family: var(--serif); color: var(--text-secondary);">
      Ingénieur civil et expert immobilier à Genève. Ici je partage ce que j'observe dans la construction et l'immobilier en Suisse — rénovation énergétique, gestion de chantier, réglementation, valorisation.
    </p>
  </section>

  <!-- Latest writing -->
  <section class="mb-20 md:mb-24 reveal">
    <p class="section-header">Dernières réflexions</p>
    <div class="space-y-7">
      {posts.slice(0, 5).map((post) => (
        <a href={`/reflexions/${post.id}`} class="group block no-underline">
          <span class="text-xs tracking-wide" style="font-family: var(--mono); color: var(--text-muted);">
            {post.data.date.toLocaleDateString('fr-CH', { year: 'numeric', month: 'long' })}
          </span>
          <h3 class="text-lg font-medium leading-snug mt-1 group-hover:text-accent transition-colors" style="font-family: var(--serif); color: var(--text); letter-spacing: -0.01em;">
            {post.data.title}
          </h3>
          <p class="text-sm mt-1.5 line-clamp-2" style="color: var(--text-muted);">
            {post.data.description}
          </p>
        </a>
      ))}
    </div>
    <a href="/reflexions" class="inline-block mt-8 text-[13px] no-underline transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
      Toutes les réflexions →
    </a>
  </section>

  <!-- Selected projects -->
  <section class="reveal">
    <p class="section-header">Réalisations sélectionnées</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/realisations" class="card group no-underline">
        <span class="text-xs" style="font-family: var(--mono); color: var(--text-muted);">2025</span>
        <h3 class="font-semibold mt-2 group-hover:text-accent transition-colors" style="color: var(--text);">Expertise technique</h3>
        <p class="text-sm mt-1" style="color: var(--text-muted);">CECB E → B · -84% consommation</p>
      </a>
      <a href="/realisations" class="card group no-underline">
        <span class="text-xs" style="font-family: var(--mono); color: var(--text-muted);">2023</span>
        <h3 class="font-semibold mt-2 group-hover:text-accent transition-colors" style="color: var(--text);">The Ivy | Malagnou</h3>
        <p class="text-sm mt-1" style="color: var(--text-muted);">10 appts très haut standing · THPE</p>
      </a>
      <a href="/realisations" class="card group no-underline">
        <span class="text-xs" style="font-family: var(--mono); color: var(--text-muted);">2019</span>
        <h3 class="font-semibold mt-2 group-hover:text-accent transition-colors" style="color: var(--text);">Étoile-Palettes</h3>
        <p class="text-sm mt-1" style="color: var(--text-muted);">280 logements · Rénovation en site occupé</p>
      </a>
      <a href="/realisations" class="card group no-underline">
        <span class="text-xs" style="font-family: var(--mono); color: var(--text-muted);">2017</span>
        <h3 class="font-semibold mt-2 group-hover:text-accent transition-colors" style="color: var(--text);">Vaudoise Aréna</h3>
        <p class="text-sm mt-1" style="color: var(--text-muted);">9'600 places · Centre Sportif de Malley</p>
      </a>
    </div>
    <a href="/realisations" class="inline-block mt-8 text-[13px] no-underline transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
      Toutes les réalisations →
    </a>
  </section>
</BaseLayout>
