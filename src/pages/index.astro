---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <!-- Hero — à la Matthew Strom -->
  <section class="mb-20">
    <p class="text-[22px] md:text-[26px] font-light leading-[1.5] text-text-secondary" style="font-family: var(--font-serif);">
      Ici je partage ce que j'observe au quotidien dans la construction et l'immobilier en Suisse — rénovation énergétique, gestion de chantier, réglementation, valorisation.
    </p>
  </section>

  <!-- Dernières réflexions -->
  <section class="mb-20 reveal">
    <h2 class="text-[13px] font-semibold uppercase tracking-widest text-text-muted mb-8">Dernières réflexions</h2>
    <div class="space-y-6">
      {posts.slice(0, 5).map((post) => (
        <a href={`/reflexions/${post.id}`} class="group block no-underline">
          <p class="text-[12px] font-mono text-text-muted mb-1">
            {post.data.date.toLocaleDateString('fr-CH', { year: 'numeric', month: 'long' })}
          </p>
          <h3 class="text-lg font-medium text-text group-hover:text-accent transition-colors leading-snug" style="font-family: var(--font-serif);">
            {post.data.title}
          </h3>
          <p class="text-[14px] text-text-muted mt-1 line-clamp-2">{post.data.description}</p>
        </a>
      ))}
    </div>
    <p class="mt-8">
      <a href="/reflexions" class="text-[13px] text-text-muted no-underline hover:text-accent transition-colors">Toutes les réflexions →</a>
    </p>
  </section>

  <!-- Réalisations sélectionnées -->
  <section class="reveal">
    <h2 class="text-[13px] font-semibold uppercase tracking-widest text-text-muted mb-8">Réalisations sélectionnées</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/realisations" class="card group no-underline">
        <p class="text-[12px] font-mono text-text-muted mb-2">2025</p>
        <h3 class="font-medium text-text group-hover:text-accent transition-colors mb-1">Expertise technique</h3>
        <p class="text-[14px] text-text-muted">CECB E → B · -84% de consommation énergétique</p>
      </a>
      <a href="/realisations" class="card group no-underline">
        <p class="text-[12px] font-mono text-text-muted mb-2">2023</p>
        <h3 class="font-medium text-text group-hover:text-accent transition-colors mb-1">The Ivy | Malagnou</h3>
        <p class="text-[14px] text-text-muted">10 appartements très haut standing · THPE</p>
      </a>
      <a href="/realisations" class="card group no-underline">
        <p class="text-[12px] font-mono text-text-muted mb-2">2019</p>
        <h3 class="font-medium text-text group-hover:text-accent transition-colors mb-1">Étoile-Palettes</h3>
        <p class="text-[14px] text-text-muted">280 logements · Rénovation en site occupé</p>
      </a>
      <a href="/realisations" class="card group no-underline">
        <p class="text-[12px] font-mono text-text-muted mb-2">2017</p>
        <h3 class="font-medium text-text group-hover:text-accent transition-colors mb-1">Vaudoise Aréna</h3>
        <p class="text-[14px] text-text-muted">9'600 places · Centre Sportif de Malley</p>
      </a>
    </div>
    <p class="mt-8">
      <a href="/realisations" class="text-[13px] text-text-muted no-underline hover:text-accent transition-colors">Toutes les réalisations →</a>
    </p>
  </section>
</BaseLayout>
