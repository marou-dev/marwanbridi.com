---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">
      <span class="hero-word">Construire.</span>
      <span class="hero-word">Évaluer.</span>
      <span class="hero-word"><span class="accent">Transformer.</span></span>
    </h1>
    <p class="hero-subtitle">
      Ingénieur construction basé à Genève. De la conception au chantier, de la valorisation immobilière à l'IA appliquée — je couvre toute la chaîne.
    </p>
  </section>

  <!-- Parcours -->
  <section class="section reveal">
    <h2>Parcours</h2>
    <p>
      ESTP Paris → Steiner SA → Halter AG → Wuest Partner → Project Manager dans la promotion immobilière à Genève.
    </p>
    <p>
      Construction neuve, rénovation, valorisation d'actifs, appels d'offres, data immobilière, IA en production — chaque étape m'a donné une pièce du puzzle.
    </p>
    <div class="logo-wall">
      <span>ESTP Paris</span>
      <span>Steiner</span>
      <span>Halter</span>
      <span>Wuest Partner</span>
    </div>
  </section>

  <hr class="separator" />

  <!-- Ce que je fais -->
  <section class="section reveal">
    <h2>Ce que je fais</h2>
    <div class="featured-grid">
      <div class="card">
        <h3>Construction</h3>
        <p class="desc">Pilotage de projets, coordination tous corps d'état, appels d'offres, suivi chantier, maîtrise des coûts.</p>
      </div>
      <div class="card">
        <h3>Évaluation</h3>
        <p class="desc">Valorisation immobilière, analyse DCF, due diligence technique, études de faisabilité.</p>
      </div>
      <div class="card">
        <h3>Digital & IA</h3>
        <p class="desc">RAG contractuel, Knowledge Graphs, extraction automatique, pipelines de données opérationnels.</p>
      </div>
      <div class="card">
        <h3>Immobilier</h3>
        <p class="desc">Valorisation d'actifs, faisabilité, LDTR, optimisation coûts, direction de travaux.</p>
      </div>
    </div>
  </section>
</BaseLayout>
