---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <section class="hero">
    <p>
      Notre industrie bouge et peu de gens écrivent dessus de l'intérieur. Ici je partage ce que j'observe — marché immobilier suisse, rénovation énergétique, gestion de chantier, et ce qui change réellement la pratique.
    </p>
  </section>

  <hr class="separator" />

  <section class="section reveal">
    <h2>Dernières réflexions</h2>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/reflexions/${post.id}`}>
            <span class="date">
              {post.data.date.toLocaleDateString('fr-CH', {
                year: 'numeric',
                month: '2-digit',
              })}
            </span>
            <span class="title">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
    <p style="margin-top: 1rem;">
      <a href="/reflexions">Toutes les réflexions →</a>
    </p>
  </section>

  <hr class="separator" />

  <section class="section reveal">
    <h2>Réalisations</h2>
    <p class="muted" style="margin-bottom: 1rem;">Projets personnels et explorations techniques.</p>
    <div>
      <a href="/realisations" style="text-decoration: none; color: inherit;">
        <div class="card">
          <h3>RAG Contractuel</h3>
          <p class="desc">Recherche sémantique sur les documents contractuels en construction.</p>
        </div>
      </a>
      <a href="/realisations" style="text-decoration: none; color: inherit;">
        <div class="card">
          <h3>Base de prix unitaires</h3>
          <p class="desc">8'356 positions, 68 CFC, 9 projets — extraction automatique depuis les soumissions.</p>
        </div>
      </a>
    </div>
    <p style="margin-top: 0.5rem;">
      <a href="/realisations">Toutes les réalisations →</a>
    </p>
  </section>
</BaseLayout>
