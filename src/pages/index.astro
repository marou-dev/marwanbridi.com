---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <section class="mb-12">
    <p class="text-lg leading-relaxed text-text-secondary max-w-[600px]">
      Ici je partage ce que j'observe au quotidien dans la construction et l'immobilier en Suisse — rénovation énergétique, gestion de chantier, réglementation, valorisation.
    </p>
  </section>

  <hr class="border-border mb-10" />

  <section class="mb-14 reveal">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Dernières réflexions</h2>
    <ul class="space-y-0">
      {posts.slice(0, 5).map((post) => (
        <li>
          <a href={`/reflexions/${post.id}`} class="group flex gap-5 items-baseline py-3 border-b border-border no-underline transition-colors hover:text-accent">
            <span class="text-xs font-mono text-text-muted tabular-nums whitespace-nowrap">
              {post.data.date.toLocaleDateString('fr-CH', { year: 'numeric', month: '2-digit' })}
            </span>
            <span class="font-medium group-hover:text-accent transition-colors">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="mt-4">
      <a href="/reflexions" class="text-sm text-text-muted hover:text-accent transition-colors">Toutes les réflexions →</a>
    </p>
  </section>

  <hr class="border-border mb-10" />

  <section class="reveal">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Réalisations</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href="/realisations" class="card no-underline group">
        <h3 class="font-semibold text-text group-hover:text-accent transition-colors">Expertise technique <span class="text-text-muted font-normal">· 2025</span></h3>
        <p class="text-sm text-text-muted mt-1">CECB E → B, -84% de consommation.</p>
      </a>
      <a href="/realisations" class="card no-underline group">
        <h3 class="font-semibold text-text group-hover:text-accent transition-colors">The Ivy | Malagnou <span class="text-text-muted font-normal">· 2023</span></h3>
        <p class="text-sm text-text-muted mt-1">10 appartements très haut standing, Chêne-Bougeries.</p>
      </a>
    </div>
    <p class="mt-4">
      <a href="/realisations" class="text-sm text-text-muted hover:text-accent transition-colors">Toutes les réalisations →</a>
    </p>
  </section>
</BaseLayout>
