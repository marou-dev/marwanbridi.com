---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <section class="hero">
    <p>
      Ici je partage ce que j'observe au quotidien dans la construction et l'immobilier en Suisse — rénovation énergétique, gestion de chantier, réglementation, valorisation.
    </p>
  </section>

  <hr class="separator" />

  <section class="section reveal">
    <h2>Dernières réflexions</h2>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/reflexions/${post.id}`}>
            <span class="date">
              {post.data.date.toLocaleDateString('fr-CH', {
                year: 'numeric',
                month: '2-digit',
              })}
            </span>
            <span class="title">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
    <p style="margin-top: 1rem;">
      <a href="/reflexions">Toutes les réflexions →</a>
    </p>
  </section>

  <hr class="separator" />

  <section class="section reveal">
    <h2>Réalisations</h2>
    <p class="muted" style="margin-bottom: 1rem;">Construction, rénovation, évaluation — du terrain à l'analyse.</p>
    <div>
      <a href="/realisations" style="text-decoration: none; color: inherit;">
        <div class="card">
          <h3>Expertise technique — CECB E → B <span class="muted">· 2025</span></h3>
          <p class="desc">Diagnostic complet et stratégie de rénovation énergétique, -84% de consommation.</p>
        </div>
      </a>
      <a href="/realisations" style="text-decoration: none; color: inherit;">
        <div class="card">
          <h3>The Ivy | Malagnou — Très haut standing <span class="muted">· 2023</span></h3>
          <p class="desc">10 appartements, label THPE, Chêne-Bougeries.</p>
        </div>
      </a>
    </div>
    <p style="margin-top: 0.5rem;">
      <a href="/realisations">Toutes les réalisations →</a>
    </p>
  </section>
</BaseLayout>
