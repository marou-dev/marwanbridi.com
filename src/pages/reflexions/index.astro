---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<BaseLayout title="Réflexions — Marwan Bridi">
  <section class="mb-8">
    <h2 class="text-2xl font-semibold tracking-tight mb-3">Réflexions</h2>
    <p class="text-sm text-text-muted mb-5">
      Immobilier, construction, énergie, réglementation — ce que j'observe et ce que j'en tire.
    </p>
    <div class="flex flex-wrap gap-1.5 mb-8">
      <button class="chip tag-filter active" data-tag="all">Tout</button>
      {allTags.map((tag) => (
        <button class="chip tag-filter" data-tag={tag}>{tag}</button>
      ))}
    </div>
  </section>

  {posts.length === 0 ? (
    <p class="text-text-muted reveal">Premiers articles en préparation.</p>
  ) : (
    <ul class="space-y-0">
      {posts.map((post) => (
        <li class="reveal" data-tags={JSON.stringify(post.data.tags || [])}>
          <a href={`/reflexions/${post.id}`} class="group flex gap-5 items-baseline py-3.5 border-b border-border no-underline transition-colors">
            <span class="text-xs font-mono text-text-muted tabular-nums whitespace-nowrap">
              {post.data.date.toLocaleDateString('fr-CH', { year: 'numeric', month: '2-digit' })}
            </span>
            <span class="font-medium group-hover:text-accent transition-colors">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tag-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      document.querySelectorAll('.tag-filter').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('li[data-tags]').forEach((li) => {
        if (tag === 'all') { li.style.display = ''; }
        else {
          const tags = JSON.parse(li.getAttribute('data-tags') || '[]');
          li.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>
