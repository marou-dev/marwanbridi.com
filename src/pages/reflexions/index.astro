---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<BaseLayout title="Réflexions — Marwan Bridi">
  <section class="mb-10">
    <h2 class="text-[13px] font-semibold uppercase tracking-widest text-text-muted mb-6">Réflexions</h2>
    <div class="flex flex-wrap gap-2 mb-10">
      <button class="chip tag-filter active" data-tag="all">Tout</button>
      {allTags.map((tag) => (
        <button class="chip tag-filter" data-tag={tag}>{tag}</button>
      ))}
    </div>
  </section>

  <div class="space-y-8">
    {posts.map((post) => (
      <a href={`/reflexions/${post.id}`} class="group block no-underline reveal" data-tags={JSON.stringify(post.data.tags || [])}>
        <p class="text-[12px] font-mono text-text-muted mb-1">
          {post.data.date.toLocaleDateString('fr-CH', { year: 'numeric', month: 'long' })}
        </p>
        <h3 class="text-lg font-medium text-text group-hover:text-accent transition-colors leading-snug" style="font-family: var(--font-serif);">
          {post.data.title}
        </h3>
        <p class="text-[14px] text-text-muted mt-1.5 line-clamp-2">{post.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tag-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      document.querySelectorAll('.tag-filter').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('a[data-tags]').forEach((el) => {
        if (tag === 'all') { el.style.display = ''; }
        else {
          const tags = JSON.parse(el.getAttribute('data-tags') || '[]');
          el.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>
