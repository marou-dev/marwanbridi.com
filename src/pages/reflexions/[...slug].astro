---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('thinking');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Marwan Bridi`} description={post.data.description}>
  <article>
    <header class="mb-10">
      <p class="text-xs tracking-wide mb-4" style="font-family: var(--mono); color: var(--text-muted);">
        {post.data.date.toLocaleDateString('fr-CH', { year: 'numeric', month: 'long', day: 'numeric' })}
        {post.data.tags && <span> · {post.data.tags.join(' · ')}</span>}
      </p>
      <h1 class="text-2xl md:text-[2rem] font-medium leading-tight tracking-tight" style="font-family: var(--serif); color: var(--text);">
        {post.data.title}
      </h1>
    </header>

    <div class="article-body">
      <Content />
    </div>
  </article>

  <div class="mt-14 pt-6 border-t" style="border-color: var(--border);">
    <a href="/reflexions" class="text-[13px] no-underline transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">← Toutes les réflexions</a>
  </div>
</BaseLayout>
