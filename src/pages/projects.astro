---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects — Marwan Bridi">
  <h2>Projects</h2>

  <div class="project">
    <h3>GeoValuation</h3>
    <p class="desc">Plateforme SaaS de valorisation immobilière DCF géo-contextualisée. Couches fédérales suisses, données SITG, modèles de risque environnemental.</p>
    <p class="meta">PropTech — MVP 2026</p>
  </div>

  <div class="project">
    <h3>RAG PV Adjudication</h3>
    <p class="desc">Recherche sémantique sur les procès-verbaux d'adjudication Swissroc. Extraction automatique des clauses, prix unitaires, conditions contractuelles.</p>
    <p class="meta">IA + Construction — En production</p>
  </div>

  <div class="project">
    <h3>Knowledge Graph Pipeline</h3>
    <p class="desc">Pipeline d'extraction d'entités depuis un vault Obsidian de 19K+ notes vers Neo4j. Détection de relations, résolution d'alias, couches de sécurité.</p>
    <p class="meta">NLP + Graph — En production</p>
  </div>

  <div class="project">
    <h3>Personal-OS</h3>
    <p class="desc">Système de knowledge management personnel — Obsidian + Claude Code + n8n + Neo4j. Skills markdown, daily loops automatisées, veille IA structurée.</p>
    <p class="meta">Productivité + IA — Quotidien</p>
  </div>

  <div class="project">
    <h3>BOH Partners</h3>
    <p class="desc">Cabinet conseil AMO immobilier. LDTR, optimisation coûts, direction de travaux — Genève et Vaud.</p>
    <p class="meta">Conseil immobilier</p>
  </div>
</BaseLayout>
