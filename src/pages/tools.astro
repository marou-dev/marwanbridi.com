---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Stack — Marwan Bridi">
  <section class="section">
    <h2>Stack</h2>
    <p class="hero-subtitle" style="margin-bottom: 2rem;">
      Des outils simples, composables, en production. Pas de slides sur "l'IA du futur" — du code qui tourne aujourd'hui.
    </p>
  </section>

  <section class="section reveal">
    <h3>Knowledge</h3>
    <div class="chip-grid">
      <span class="chip">Obsidian</span>
      <span class="chip">Neo4j</span>
      <span class="chip">Claude Code</span>
      <span class="chip">Markdown Skills</span>
    </div>
  </section>

  <section class="section reveal">
    <h3>Automatisation</h3>
    <div class="chip-grid">
      <span class="chip">Python</span>
      <span class="chip">n8n</span>
      <span class="chip">GitHub Actions</span>
      <span class="chip">NLP / LLM</span>
    </div>
  </section>

  <section class="section reveal">
    <h3>Construction & Immobilier</h3>
    <div class="chip-grid">
      <span class="chip">Procore</span>
      <span class="chip">Monday.com</span>
      <span class="chip">Google Sheets</span>
      <span class="chip">Apps Script</span>
    </div>
  </section>

  <hr class="separator" />

  <section class="section reveal">
    <h3>Philosophie</h3>
    <div class="card">
      <p class="desc" style="margin-bottom: 0;">
        Le vault est la source de vérité. Skills Markdown > infrastructure complexe. L'IA amplifie ce qui existe — elle ne remplace pas la pensée structurée.
      </p>
    </div>
  </section>
</BaseLayout>
