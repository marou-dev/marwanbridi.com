---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Thinking — Marwan Bridi">
  <section class="section">
    <h2>Thinking</h2>
    <p class="muted" style="margin-bottom: 2rem;">
      Notes sur l'IA dans la construction, la PropTech, et ce qui marche en production.
    </p>
  </section>

  {posts.length === 0 ? (
    <p class="muted reveal">Premiers articles en préparation.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="reveal">
          <a href={`/thinking/${post.id}`}>
            <span class="date">
              {post.data.date.toLocaleDateString('fr-CH', {
                year: 'numeric',
                month: '2-digit',
              })}
            </span>
            <span class="title">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
