---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Marwan Bridi",
    "jobTitle": "Project Manager Innovation",
    "url": "https://marwanbridi.com/parcours",
    "worksFor": {
      "@type": "Organization",
      "name": "Swissroc Group Services SA",
      "address": { "@type": "PostalAddress", "addressLocality": "Genève", "addressCountry": "CH" }
    },
    "alumniOf": [
      { "@type": "CollegeOrUniversity", "name": "EPFL", "description": "MAS Expert en immobilier" },
      { "@type": "CollegeOrUniversity", "name": "HEIA-FR", "description": "CAS Expertise technique" },
      { "@type": "CollegeOrUniversity", "name": "Université de Fribourg", "description": "CAS Droit de l'expertise" },
      { "@type": "CollegeOrUniversity", "name": "ESTP Paris", "description": "Ingénieur génie civil" },
      { "@type": "HighSchool", "name": "Phillips Academy Andover" }
    ],
    "knowsLanguage": ["fr", "en", "ar"]
  }
};
---

<BaseLayout title="Parcours — Marwan Bridi" jsonLd={jsonLd}>
  <section class="section">
    <h2>Parcours</h2>
    <p class="hero-subtitle">D'Andover à Genève — 15 ans à traverser toute la chaîne immobilière.</p>
  </section>

  <!-- Formation -->
  <section class="section reveal">
    <h3>Formation</h3>

    <div class="card">
      <h3>MAS Expert en immobilier — EPFL</h3>
      <p class="desc">En cours</p>
      <p class="desc">Le programme de référence en Suisse pour l'expertise immobilière. Trois CAS complémentaires : la technique du bâtiment, l'économie de l'immobilier et le cadre juridique.</p>
    </div>

    <div class="card">
      <h3>CAS Expertise technique — HEIA-FR · 2025</h3>
      <p class="desc">Apprendre à lire un bâtiment : identifier les pathologies, comprendre les causes, proposer les bons travaux. Le regard de l'ingénieur qui a vu des chantiers, appliqué à l'expertise.</p>
    </div>

    <div class="card">
      <h3>CAS Droit de l'expertise — Université de Fribourg · 2021</h3>
      <p class="desc">Le cadre dans lequel un expert opère : responsabilité, procédure civile, arbitrage, expropriation. Indispensable pour que l'expertise technique tienne devant un tribunal.</p>
    </div>

    <div class="card">
      <h3>CAS Expertise économique — EPFL · 2020</h3>
      <p class="desc">Les méthodes de valorisation (DCF, comparaison, rendement, valeur intrinsèque), la fiscalité immobilière, les indices de marché. Le langage commun entre l'ingénieur et l'investisseur.</p>
    </div>

    <div class="card">
      <h3>Ingénieur génie civil — ESTP Paris · 2017</h3>
      <p class="desc">L'ESTP forme les ingénieurs construction de référence en France. Structures, béton, géotechnique, hydraulique — les fondamentaux du métier avant de les appliquer sur le terrain.</p>
    </div>

    <div class="card">
      <h3>CPGE Maths-Physique — Lycée Masséna, Nice · 2013</h3>
      <p class="desc">Deux ans de formation intensive en mathématiques et physique.</p>
    </div>

    <div class="card">
      <h3>Phillips Academy Andover — Massachusetts · 2010</h3>
      <p class="desc">Une année dans l'un des établissements les plus sélectifs au monde, fondé en 1778. Baccalauréat américain.</p>
      <p class="desc"><strong>Bourse John Mason Kemper</strong> — 40'000 USD, 4 européens sélectionnés.<br /><strong>Prix James Hooper Grew</strong> — pour l'enseignement du français à des étudiants étrangers.</p>
      <p class="desc">Immersion complète en anglais dans un environnement académique international.</p>
    </div>
  </section>

  <hr class="separator" />

  <!-- Expérience -->
  <section class="section reveal">
    <h3>Expérience</h3>

    <div class="card">
      <h3>Swissroc Group Services SA — Genève</h3>
      <p class="desc">Project Manager Innovation · Depuis 2023</p>
      <p class="desc">Swissroc est un groupe de 9 entités dans la construction et l'immobilier à Genève. Après avoir piloté des projets en entreprise totale puis créé et structuré le pôle achats du groupe, je pilote aujourd'hui l'innovation au service de l'ensemble du groupe, rattaché au COO — digitalisation des processus, data, IA appliquée à la construction et à l'immobilier.</p>
    </div>

    <div class="card">
      <h3>Wüest Partner SA — Genève</h3>
      <p class="desc">Consultant en immobilier · 2020 — 2021</p>
      <p class="desc">Wüest Partner est la référence suisse en data et valorisation immobilière. Évaluation d'actifs résidentiels, commerciaux et industriels pour des institutionnels et des fonds FINMA. C'est là que j'ai appris à parler le langage des investisseurs — DCF, méthode du promoteur, comparaison — et à produire des analyses qui engagent des décisions à plusieurs dizaines de millions.</p>
    </div>

    <div class="card">
      <h3>Halter SA — Genève & Lausanne</h3>
      <p class="desc">Chef de projet · 2018 — 2020</p>
      <p class="desc">Halter est un développeur-constructeur majeur en Suisse. Rénovation de 280 logements en site occupé pour Patrimonium AG (Grand-Lancy). Rénovation de 500 m² de bureaux au Flon en totale autonomie — adjudications, finances, travaux, 3 mois de délai. Soumissions et adjudications CFC 27 pour un hôtel lifestyle Mobimo dans le quartier du Flon.</p>
    </div>

    <div class="card">
      <h3>Steiner SA (aujourd'hui Alpenda) — Prilly</h3>
      <p class="desc">Conducteur de travaux · 2017 — 2018</p>
      <p class="desc">Steiner est l'une des plus grandes entreprises générales de Suisse. Construction de la patinoire du Centre Sportif de Malley — phases SIA 41 à 52 sur l'Arena, en autonomie. En parallèle : rénovation et construction d'une école de 12 MCHF avec gestion de délais serrés.</p>
    </div>

    <div class="card">
      <h3>Kaufman & Broad — Marseille</h3>
      <p class="desc">Assistant responsable technique · 2016</p>
      <p class="desc">Premier promoteur immobilier coté en France. Livraison et pré-visites d'un programme immobilier en autonomie — le premier contact avec la chaîne complète, du chantier au client final.</p>
    </div>

    <div class="card">
      <h3>Cardinal Edifice (NGE) — Cagnes-sur-Mer</h3>
      <p class="desc">Conducteur de travaux stagiaire · 2014 — 2015</p>
      <p class="desc">Construction de Polygone Riviera — 70'000 m², premier lifestyle mall de France, pour Unibail-Rodamco. Un chantier d'une échelle rare pour un stagiaire.</p>
    </div>
  </section>

  <hr class="separator" />

  <!-- Compétences -->
  <section class="section reveal">
    <h3>Compétences</h3>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Construction</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Gestion de projets</span>
      <span class="chip">Appels d'offres</span>
      <span class="chip">Suivi chantier</span>
      <span class="chip">CFC / Soumissions</span>
      <span class="chip">Coordination TCE</span>
      <span class="chip">Phases SIA</span>
      <span class="chip">LDTR</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Évaluation & Immobilier</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Valorisation DCF</span>
      <span class="chip">Due diligence</span>
      <span class="chip">Faisabilité</span>
      <span class="chip">Analyse de portefeuille</span>
      <span class="chip">Droit immobilier</span>
      <span class="chip">Diagnostic pathologies</span>
      <span class="chip">Audits FINMA</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Digital & IA</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Python</span>
      <span class="chip">RAG / LLM</span>
      <span class="chip">NLP</span>
      <span class="chip">n8n</span>
      <span class="chip">Procore</span>
      <span class="chip">Product Owner (PSPO)</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Langues</p>
    <div class="chip-grid">
      <span class="chip">Français — natif</span>
      <span class="chip">Anglais — courant</span>
      <span class="chip">Arabe — courant</span>
    </div>
  </section>
</BaseLayout>
