---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV — Marwan Bridi">
  <section class="section">
    <h2>Curriculum Vitae</h2>
    <p class="hero-subtitle">Ingénieur construction · Expert immobilier · Genève</p>
  </section>

  <!-- Formation -->
  <section class="section reveal">
    <h3>Formation</h3>

    <div class="card">
      <h3>MAS Expert en immobilier (candidat)</h3>
      <p class="desc">EPFL — En cours</p>
      <p class="desc">Triple expertise : technique, économique et juridique. Le diplôme de référence en expertise immobilière en Suisse.</p>
    </div>

    <div class="card">
      <h3>CAS Expertise technique dans l'immobilier — 2025</h3>
      <p class="desc">HEIA-FR, Fribourg</p>
      <p class="desc">Diagnostic bâtiment, pathologies constructives, méthodes d'investigation, propositions de rénovation.</p>
    </div>

    <div class="card">
      <h3>CAS Droit de l'expertise dans l'immobilier — 2021</h3>
      <p class="desc">Université de Fribourg</p>
      <p class="desc">Procédure civile, responsabilité de l'expert, arbitrage, expropriation, poursuite et faillite.</p>
    </div>

    <div class="card">
      <h3>CAS Expertise économique dans l'immobilier — 2020</h3>
      <p class="desc">EPFL — Laboratoire LEURE</p>
      <p class="desc">Valorisation DCF, comparaison, rendement, valeur intrinsèque. Indices de prix, fiscalité, analyse de risque.</p>
    </div>

    <div class="card">
      <h3>Diplôme d'ingénieur — Génie civil — 2017</h3>
      <p class="desc">ESTP Paris</p>
      <p class="desc">École Spéciale des Travaux Publics. Grande école d'ingénieurs de référence en construction en France.</p>
    </div>

    <div class="card">
      <h3>Classes préparatoires (CPGE) — 2013</h3>
      <p class="desc">Lycée Masséna, Nice</p>
      <p class="desc">Filière Maths-Physique (MPSI/MP). Deux ans de formation intensive en sciences fondamentales.</p>
    </div>

    <div class="card">
      <h3>Phillips Academy Andover — 2010</h3>
      <p class="desc">Massachusetts, USA</p>
      <p class="desc">Baccalauréat américain. Bourse d'excellence "John Mason Kemper" de 40'000 USD (4 européens sélectionnés). Lauréat du prix "James Hooper Grew" pour l'enseignement du français.</p>
    </div>

    <div class="card">
      <h3>Baccalauréat scientifique — 2009</h3>
      <p class="desc">Lycée Audiberti, Antibes</p>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section reveal">
    <h3>Certifications</h3>
    <div class="chip-grid">
      <span class="chip">PSPO I — Scrum.org</span>
    </div>
  </section>

  <!-- Expérience -->
  <section class="section reveal">
    <h3>Expérience</h3>

    <div class="card">
      <h3>Responsable Achats — Swissroc Construction SA</h3>
      <p class="desc">Juin 2023 — Actuel · Genève</p>
      <p class="desc">Mise en place d'un pôle achat et d'une stratégie achats groupe. Management de projet en entreprise totale — 10 appartements de luxe (Malagnou 155), villas mitoyennes.</p>
    </div>

    <div class="card">
      <h3>Consultant en Immobilier — Wüest Partner SA</h3>
      <p class="desc">Avril 2020 — Mars 2021 · Genève</p>
      <p class="desc">Évaluation d'actifs immobiliers (résidentiel, commercial, industriel) — DCF, méthode du promoteur, comparaison. Audits trimestriels pour fonds FINMA.</p>
    </div>

    <div class="card">
      <h3>Chef de projet — Halter SA</h3>
      <p class="desc">Novembre 2018 — Avril 2020 · Genève & Lausanne</p>
