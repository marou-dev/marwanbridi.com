---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV — Marwan Bridi">
  <section class="section">
    <h2>Curriculum Vitae</h2>
    <p class="hero-subtitle">Ingénieur construction · Genève</p>
  </section>

  <!-- Formation -->
  <section class="section reveal">
    <h3>Formation</h3>
    <div class="card">
      <h3>ESTP Paris</h3>
      <p class="desc">Diplôme d'ingénieur — Génie civil & Construction</p>
    </div>
  </section>

  <!-- Expérience -->
  <section class="section reveal">
    <h3>Expérience</h3>

    <div class="card">
      <h3>Project Manager — Promotion immobilière</h3>
      <p class="desc">Genève · Actuel</p>
      <p class="desc">Pilotage de projets de construction neuve et rénovation. Coordination tous corps d'état, maîtrise des coûts et des délais. Digitalisation des processus opérationnels.</p>
    </div>

    <div class="card">
      <h3>Wuest Partner</h3>
      <p class="desc">Data & Valorisation immobilière</p>
      <p class="desc">Évaluation d'actifs, modèles DCF, analyse de portefeuilles immobiliers, data processing.</p>
    </div>

    <div class="card">
      <h3>Halter AG</h3>
      <p class="desc">Construction & Développement</p>
      <p class="desc">Gestion de projets, entreprise générale, coordination de chantiers en Suisse alémanique.</p>
    </div>

    <div class="card">
      <h3>Steiner SA</h3>
      <p class="desc">Construction</p>
      <p class="desc">Suivi de chantier, appels d'offres, gestion des sous-traitants.</p>
    </div>
  </section>

  <!-- Compétences -->
  <section class="section reveal">
    <h3>Compétences</h3>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Construction</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Gestion de projets</span>
      <span class="chip">Appels d'offres</span>
      <span class="chip">Suivi chantier</span>
      <span class="chip">CFC / Soumissions</span>
      <span class="chip">Coordination TCE</span>
      <span class="chip">LDTR</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Évaluation & Immobilier</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Valorisation DCF</span>
      <span class="chip">Due diligence technique</span>
      <span class="chip">Faisabilité</span>
      <span class="chip">Analyse de portefeuille</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Digital & IA</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Python</span>
      <span class="chip">RAG / LLM</span>
      <span class="chip">Neo4j</span>
      <span class="chip">NLP</span>
      <span class="chip">n8n</span>
      <span class="chip">Procore</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Langues</p>
    <div class="chip-grid">
      <span class="chip">Français — natif</span>
      <span class="chip">Anglais — courant</span>
      <span class="chip">Arabe — natif</span>
      <span class="chip">Allemand — opérationnel</span>
    </div>
  </section>
</BaseLayout>
