      <span class="chip">Arabe — courant</span>
      <span class="chip">Allemand — opérationnel</span>
    </div>
  </section>

  <!-- Bourses & Prix -->
  <section class="section reveal">
    <h3>Distinctions</h3>
    <div class="card">
      <h3>Bourse "John Mason Kemper"</h3>
      <p class="desc">40'000 USD — Phillips Academy Andover. 4 européens sélectionnés.</p>
    </div>
    <div class="card">
      <h3>Prix "James Hooper Grew"</h3>
      <p class="desc">Pour l'enseignement du français à des étudiants étrangers — Phillips Academy Andover.</p>
    </div>
  </section>
