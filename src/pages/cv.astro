---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV — Marwan Bridi">
  <section class="section">
    <h2>Curriculum Vitae</h2>
    <p class="hero-subtitle">Ingénieur construction · Genève</p>
  </section>

  <!-- Formation -->
  <section class="section reveal">
    <h3>Formation</h3>

    <div class="card">
      <h3>MAS Expert en immobilier (candidat)</h3>
      <p class="desc">EPFL — En cours</p>
      <p class="desc">Le diplôme de référence en expertise immobilière en Suisse. Combine expertise technique, économique et juridique.</p>
    </div>

    <div class="card">
      <h3>CAS Expertise économique dans l'immobilier</h3>
      <p class="desc">EPFL — Laboratoire LEURE</p>
      <p class="desc">Valorisation immobilière : méthodes DCF, comparaison, rendement, valeur intrinsèque. Indices de prix, fiscalité, analyse de risque.</p>
    </div>

    <div class="card">
      <h3>CAS Droit de l'expertise dans l'immobilier</h3>
      <p class="desc">Université de Fribourg</p>
      <p class="desc">Cadre juridique de l'expertise : procédure civile, responsabilité de l'expert, arbitrage, expropriation, poursuite et faillite.</p>
    </div>

    <div class="card">
      <h3>CAS Expertise technique dans l'immobilier</h3>
      <p class="desc">HEIA-FR — Fribourg</p>
      <p class="desc">Diagnostic bâtiment : pathologies constructives, méthodes d'investigation, qualité, patrimoine, propositions de rénovation.</p>
    </div>

    <div class="card">
      <h3>Diplôme d'ingénieur — Génie civil</h3>
      <p class="desc">ESTP Paris</p>
      <p class="desc">École Spéciale des Travaux Publics. La grande école d'ingénieurs de référence en construction en France.</p>
    </div>

    <div class="card">
      <h3>Classes préparatoires (CPGE)</h3>
      <p class="desc">Lycée Masséna — Nice</p>
      <p class="desc">Maths-Physique. Plus grand pôle de classes préparatoires de l'académie de Nice — 19 divisions, 850 élèves.</p>
    </div>

    <div class="card">
      <h3>Phillips Academy Andover</h3>
      <p class="desc">Massachusetts, USA</p>
      <p class="desc">Fondée en 1778. L'un des boarding schools les plus sélectifs au monde — taux d'admission ~9%.</p>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section reveal">
    <h3>Certifications</h3>
    <div class="chip-grid">
      <span class="chip">PSPO I — Scrum.org</span>
    </div>
  </section>

  <!-- Expérience -->
  <section class="section reveal">
    <h3>Expérience</h3>

    <div class="card">
      <h3>Project Manager — Promotion immobilière</h3>
      <p class="desc">Genève · Actuel</p>
      <p class="desc">Pilotage de projets de construction neuve et rénovation. Coordination tous corps d'état, maîtrise des coûts et des délais. Digitalisation des processus opérationnels.</p>
    </div>

    <div class="card">
      <h3>Wuest Partner</h3>
      <p class="desc">Data & Valorisation immobilière</p>
      <p class="desc">Évaluation d'actifs, modèles DCF, analyse de portefeuilles immobiliers, data processing.</p>
    </div>

    <div class="card">
      <h3>Halter AG</h3>
      <p class="desc">Construction & Développement</p>
      <p class="desc">Gestion de projets, entreprise générale, coordination de chantiers en Suisse alémanique.</p>
    </div>

    <div class="card">
      <h3>Steiner SA</h3>
      <p class="desc">Construction</p>
      <p class="desc">Suivi de chantier, appels d'offres, gestion des sous-traitants.</p>
    </div>
  </section>

  <!-- Compétences -->
  <section class="section reveal">
    <h3>Compétences</h3>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Construction</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Gestion de projets</span>
      <span class="chip">Appels d'offres</span>
      <span class="chip">Suivi chantier</span>
      <span class="chip">CFC / Soumissions</span>
      <span class="chip">Coordination TCE</span>
      <span class="chip">LDTR</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Évaluation & Immobilier</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Valorisation DCF</span>
      <span class="chip">Due diligence technique</span>
      <span class="chip">Faisabilité</span>
      <span class="chip">Analyse de portefeuille</span>
      <span class="chip">Droit immobilier</span>
      <span class="chip">Diagnostic pathologies</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Digital & IA</p>
    <div class="chip-grid" style="margin-bottom: 1.5rem;">
      <span class="chip">Python</span>
      <span class="chip">RAG / LLM</span>
      <span class="chip">Neo4j</span>
      <span class="chip">NLP</span>
      <span class="chip">n8n</span>
      <span class="chip">Procore</span>
      <span class="chip">Product Owner (PSPO)</span>
    </div>

    <p style="margin-bottom: 0.75rem; color: var(--text-muted); font-size: 0.85rem;">Langues</p>
    <div class="chip-grid">
      <span class="chip">Français — natif</span>
      <span class="chip">Anglais — courant</span>
      <span class="chip">Arabe — natif</span>
      <span class="chip">Allemand — opérationnel</span>
    </div>
  </section>
</BaseLayout>
